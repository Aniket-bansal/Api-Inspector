{
  "name": "api-inspector",
  "version": "1.1.0",
  "private": true,
  "description": "Cross-browser extension that captures API requests and generates fetch / axios / cURL / Python / Go / Node / HTTPie snippets.",
  "type": "module",
  "scripts": {
    "test": "node --test \"tests/**/*.test.js\"",
    "test:watch": "node --test --watch \"tests/**/*.test.js\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "eslint": "^9.10.0",
    "globals": "^15.9.0",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20"
  }
}
